{
  "name": "deckforge-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node server/index.mjs",
    "dev:vite": "vite --host 0.0.0.0",
    "start": "node server/index.mjs --production",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:deck-agent": "vitest run tests/unit/deck-agent tests/integration/deck-agent",
    "test:attachments": "tsx scripts/test-attachment-parser.mjs",
    "test:provenance": "node scripts/test-source-provenance.mjs",
    "test:integrated-export": "tsx scripts/test-integrated-export.mjs",
    "test:image-geometry": "tsx scripts/test-image-geometry.mjs",
    "test:image-prompt": "node scripts/test-image-prompt.mjs",
    "test:html-deck": "tsx scripts/test-html-deck.mjs",
    "test:visual": "tsx scripts/test-visual-decomposition.mjs",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "css-tree": "3.2.1",
    "echarts": "6.1.0",
    "express": "^4.19.2",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "mdast-util-to-string": "4.0.0",
    "parse5": "8.0.1",
    "pdfjs-dist": "^5.4.530",
    "playwright": "1.61.1",
    "pptxgenjs": "^3.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "reveal.js": "6.0.1",
    "tesseract.js": "^7.0.0",
    "undici": "6.27.0",
    "unified": "11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "20.19.43",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "4.1.10",
    "@xmldom/xmldom": "^0.9.10",
    "jsdom": "29.1.1",
    "supertest": "7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^5.5.3",
    "vite": "^6.4.3",
    "vitest": "4.1.10"
  }
}
