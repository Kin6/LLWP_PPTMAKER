{
  "name": "deckforge-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node server/index.mjs",
    "dev:vite": "vite --host 0.0.0.0",
    "start": "node server/index.mjs --production",
    "build": "tsc -b && vite build",
    "test:attachments": "node --experimental-strip-types scripts/test-attachment-parser.mjs",
    "test:provenance": "node scripts/test-source-provenance.mjs",
    "test:integrated-export": "node --experimental-strip-types scripts/test-integrated-export.mjs",
    "test:image-geometry": "node --experimental-strip-types scripts/test-image-geometry.mjs",
    "test:image-prompt": "node scripts/test-image-prompt.mjs",
    "test:html-deck": "tsx scripts/test-html-deck.mjs",
    "test:visual": "node --experimental-strip-types scripts/test-visual-decomposition.mjs",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "echarts": "^6.1.0",
    "express": "^4.19.2",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^5.4.530",
    "pptxgenjs": "^3.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reveal.js": "^6.0.1",
    "tesseract.js": "^7.0.0",
    "undici": "^8.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@xmldom/xmldom": "^0.9.10",
    "playwright": "^1.61.1",
    "tsx": "^4.23.1",
    "typescript": "^5.5.3",
    "vite": "^6.4.3"
  }
}
