# Optional: copy this file to .env.local, then restart npm run dev.
# Existing Windows user/machine OPENAI_API_KEY variables are also detected automatically.
# The key is read only by the local Express server and is never bundled into the frontend.
OPENAI_API_KEY=
TEXT_API_BASE_URL=https://api.openai.com/v1
TEXT_MODEL=gpt-5.6-terra
IMAGE_API_BASE_URL=https://api.openai.com/v1
IMAGE_MODEL=gpt-image-2
