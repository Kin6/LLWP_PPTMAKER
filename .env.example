# Optional: copy this file to .env.local, then restart npm run dev.
# Existing Windows user/machine OPENAI_API_KEY variables are also detected automatically.
# The key is read only by the local Express server and is never bundled into the frontend.
OPENAI_API_KEY=
# Optional compatible gateway used for both text and image APIs.
OPENAI_API_BASE=
# Optional image fallback gateway used after a retryable image failure.
OPENAI_API_FALLBACK_BASE=
# Leave the specific URLs blank to inherit OPENAI_API_BASE or the official defaults.
TEXT_API_BASE_URL=
TEXT_MODEL=gpt-5.6-terra
IMAGE_API_BASE_URL=
IMAGE_API_FALLBACK_BASE_URL=
IMAGE_MODEL=gpt-image-2
IMAGE_API_TIMEOUT_MS=600000
IMAGE_API_MAX_RETRIES=1
